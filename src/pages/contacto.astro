---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../data/site';
---

<Layout
  title="Contacto | Primera Clase Gratis · Academia de Artes Marciales Garraf"
  description="Reserva tu primera clase gratis en la Academia de Artes Marciales Garraf. Llámanos, escríbenos por WhatsApp o rellena el formulario. Respuesta en menos de 2 horas."
  canonical="/contacto/"
>
  <Header />

  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <span class="inline-block bg-brand-red/15 text-brand-red text-xs font-semibold px-3 py-1 rounded-full mb-4 uppercase tracking-wider border border-brand-red/30">Primera clase gratis</span>
        <h1 class="text-3xl sm:text-4xl font-black text-white mb-4">Reserva tu primera clase</h1>
        <p class="text-brand-muted max-w-lg mx-auto">Sin compromiso, sin pago previo. Ven, prueba y decide. Respuesta garantizada en menos de 2 horas.</p>
      </div>

      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Form -->
        <div>
          <form
            id="contact-form"
            class="space-y-5"
            action="https://formspree.io/f/YOUR_FORM_ID"
            method="POST"
          >
            <div>
              <label for="nombre" class="block text-sm font-medium text-white mb-1.5">Nombre *</label>
              <input type="text" id="nombre" name="nombre" required
                class="w-full bg-brand-gray border border-brand-border rounded-lg px-4 py-3 text-white text-sm placeholder-brand-muted focus:outline-none focus:border-brand-red transition-colors"
                placeholder="Tu nombre" />
            </div>
            <div>
              <label for="telefono" class="block text-sm font-medium text-white mb-1.5">Teléfono *</label>
              <input type="tel" id="telefono" name="telefono" required
                class="w-full bg-brand-gray border border-brand-border rounded-lg px-4 py-3 text-white text-sm placeholder-brand-muted focus:outline-none focus:border-brand-red transition-colors"
                placeholder="+34 600 000 000" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-white mb-1.5">Email</label>
              <input type="email" id="email" name="email"
                class="w-full bg-brand-gray border border-brand-border rounded-lg px-4 py-3 text-white text-sm placeholder-brand-muted focus:outline-none focus:border-brand-red transition-colors"
                placeholder="tu@email.com" />
            </div>
            <div>
              <label for="disciplina" class="block text-sm font-medium text-white mb-1.5">Disciplina de interés</label>
              <select id="disciplina" name="disciplina"
                class="w-full bg-brand-gray border border-brand-border rounded-lg px-4 py-3 text-white text-sm focus:outline-none focus:border-brand-red transition-colors">
                <option value="">Selecciona una disciplina</option>
                {['Boxeo', 'Karate', 'MMA', 'Kickboxing', 'Muay Thai', 'BJJ / Jiu Jitsu Brasileño', 'Judo', 'Taekwondo', 'Defensa Personal', 'Krav Maga', 'No lo tengo claro'].map(d => (
                  <option value={d}>{d}</option>
                ))}
              </select>
            </div>
            <div>
              <label for="sede" class="block text-sm font-medium text-white mb-1.5">Sede preferida</label>
              <select id="sede" name="sede"
                class="w-full bg-brand-gray border border-brand-border rounded-lg px-4 py-3 text-white text-sm focus:outline-none focus:border-brand-red transition-colors">
                <option value="">Selecciona una sede</option>
                <option>Sitges</option>
                <option>Vilanova i la Geltrú</option>
                <option>Cualquiera</option>
              </select>
            </div>
            <div>
              <label for="mensaje" class="block text-sm font-medium text-white mb-1.5">Mensaje (opcional)</label>
              <textarea id="mensaje" name="mensaje" rows="3"
                class="w-full bg-brand-gray border border-brand-border rounded-lg px-4 py-3 text-white text-sm placeholder-brand-muted focus:outline-none focus:border-brand-red transition-colors resize-none"
                placeholder="¿Tienes alguna duda o condición especial que debamos saber?"></textarea>
            </div>
            <!-- Honeypot -->
            <input type="text" name="_gotcha" class="hidden" />
            <input type="hidden" name="_subject" value="Nueva solicitud de clase gratis - Academia Garraf" />
            <button type="submit"
              class="w-full bg-brand-red hover:bg-red-700 text-white font-bold py-4 rounded-lg transition-colors text-lg">
              Reservar clase gratis →
            </button>
            <p class="text-xs text-brand-muted text-center">Al enviar aceptas nuestra <a href="/politica-privacidad/" class="underline">política de privacidad</a>. Sin spam, sin contratos.</p>
          </form>
        </div>

        <!-- Contact info -->
        <div class="space-y-8">
          <div>
            <h2 class="text-lg font-bold text-white mb-4">O contáctanos directamente</h2>
            <div class="space-y-4">
              <a href={`tel:${SITE.phone}`}
                class="flex items-center gap-4 bg-brand-gray border border-brand-border rounded-xl p-4 hover:border-brand-red/40 transition-colors group">
                <div class="w-10 h-10 rounded-lg bg-brand-red/20 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-brand-muted">Teléfono</p>
                  <p class="font-semibold text-white group-hover:text-brand-red transition-colors">{SITE.phone}</p>
                </div>
              </a>
              <a href={`https://wa.me/${SITE.whatsapp}`} target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-4 bg-brand-gray border border-brand-border rounded-xl p-4 hover:border-green-500/40 transition-colors group">
                <div class="w-10 h-10 rounded-lg bg-green-500/20 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-brand-muted">WhatsApp</p>
                  <p class="font-semibold text-white group-hover:text-green-400 transition-colors">Respuesta inmediata</p>
                </div>
              </a>
              <a href={`mailto:${SITE.email}`}
                class="flex items-center gap-4 bg-brand-gray border border-brand-border rounded-xl p-4 hover:border-brand-red/40 transition-colors group">
                <div class="w-10 h-10 rounded-lg bg-brand-red/20 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-brand-muted">Email</p>
                  <p class="font-semibold text-white group-hover:text-brand-red transition-colors">{SITE.email}</p>
                </div>
              </a>
            </div>
          </div>

          <div>
            <h2 class="text-lg font-bold text-white mb-4">Horarios de atención</h2>
            <div class="bg-brand-gray border border-brand-border rounded-xl p-4 space-y-2">
              {SITE.hours.map(h => (
                <div class="flex justify-between text-sm">
                  <span class="text-brand-muted">{h.day}</span>
                  <span class="text-white font-medium">{h.time}</span>
                </div>
              ))}
            </div>
          </div>

          <div>
            <h2 class="text-lg font-bold text-white mb-4">Dirección</h2>
            <div class="bg-brand-gray border border-brand-border rounded-xl p-4">
              <p class="text-sm text-brand-muted">
                {SITE.address.street}<br />
                {SITE.address.city}, {SITE.address.province} {SITE.address.zip}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
