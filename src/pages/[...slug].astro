---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FAQ from '../components/FAQ.astro';
import ContactCTA from '../components/ContactCTA.astro';
import CentroCard from '../components/CentroCard.astro';
import { ALL_PAGES, type PageDef } from '../data/pages';
import { getDisciplineBySlug } from '../data/disciplines';
import { getLocationBySlug } from '../data/locations';
import { SITE } from '../data/site';
import { LOCATIONS } from '../data/locations';
import {
  getCentros,
  getCentrosCercanos,
  getCentrosByMunicipio,
  getCentrosByDisciplina,
} from '../data/centros';

export async function getStaticPaths() {
  return ALL_PAGES.map(page => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

interface Props { page: PageDef }
const { page } = Astro.props;

const discipline = page.disciplina ? getDisciplineBySlug(page.disciplina) : null;
const location   = page.municipio  ? getLocationBySlug(page.municipio)   : null;

// Schema honesto: la web es una guía (WebPage/Article), no un negocio local.
// No usar LocalBusiness hasta tener un centro cliente real con NAP verificable.
const webPageSchema = {
  "@context": "https://schema.org",
  "@type": page.type === 'blog' ? 'Article' : 'WebPage',
  "name": page.meta.title,
  "headline": page.h1,
  "description": page.meta.description,
  "url": `${SITE.url}/${page.slug}/`,
  "inLanguage": "es",
  "isPartOf": {
    "@type": "WebSite",
    "name": SITE.name,
    "url": SITE.url,
  },
  ...(location ? { "about": { "@type": "Place", "name": `${location.name}, ${location.province}` } } : {}),
};

const breadcrumbItems = [
  { "@type": "ListItem", "position": 1, "name": "Inicio", "item": SITE.url },
];
if (location) {
  breadcrumbItems.push({ "@type": "ListItem", "position": 2, "name": location.name, "item": `${SITE.url}/${location.slug}/` });
}
if (discipline && location) {
  breadcrumbItems.push({ "@type": "ListItem", "position": 3, "name": discipline.nameEs, "item": `${SITE.url}/${page.slug}/` });
} else if (discipline) {
  breadcrumbItems.push({ "@type": "ListItem", "position": 2, "name": discipline.nameEs, "item": `${SITE.url}/${page.slug}/` });
}

const breadcrumbSchema = { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": breadcrumbItems };

// Related money pages for internal linking
const relatedByMunicipio = discipline && location
  ? ALL_PAGES.filter(p => p.municipio === location.slug && p.slug !== page.slug && p.type === 'money-page').slice(0, 6)
  : [];
const relatedByDisciplina = discipline && location
  ? ALL_PAGES.filter(p => p.disciplina === discipline.slug && p.slug !== page.slug && p.type === 'money-page').slice(0, 4)
  : [];

// FAQ genérico honesto (sin horarios, sedes ni ofertas inventadas)
const genericFaq = [
  { q: '¿Necesito experiencia previa para empezar?', a: 'No. Todas las disciplinas tienen niveles de iniciación pensados para empezar desde cero. Lo importante es elegir un grupo adecuado a tu nivel.' },
  { q: '¿Cómo elijo un buen centro?', a: 'Fíjate en la titulación del instructor, en que los grupos estén separados por nivel (y por edad en el caso de los niños) y en que puedas ver o probar una clase antes de comprometerte con una cuota.' },
  { q: '¿Cuánto cuesta entrenar artes marciales?', a: 'Cada centro fija sus tarifas y cambian con el tiempo, por eso no publicamos precios. Pregunta siempre por matrícula, permanencia y clase de prueba antes de apuntarte.' },
  { q: '¿Podéis ayudarme a encontrar clase?', a: 'Sí. Escríbenos por el formulario contándonos qué disciplina te interesa, en qué municipio y para quién, y te orientamos sin coste.' },
];
// Local FAQ first (location-specific), then discipline FAQ or generic fallback
const faqItems = [
  ...(page.localFaq ?? []),
  ...(discipline?.faq ?? genericFaq),
];

// Related disciplines for hub pages
const allDisciplinesForLocation = location
  ? ALL_PAGES.filter(p => p.municipio === location.slug && p.type === 'money-page')
  : [];

// Centros reales del directorio (fuentes públicas verificadas, ver data/centros.ts)
const ordenar = (a: { nombre: string }, b: { nombre: string }) => a.nombre.localeCompare(b.nombre, 'es');
const centrosLocalDisciplina =
  discipline && location ? getCentros(location.slug, discipline.slug).sort(ordenar) : [];
const centrosCercanosDisciplina =
  discipline && location && centrosLocalDisciplina.length === 0
    ? getCentrosCercanos(location.slug, discipline.slug).sort(ordenar)
    : [];
const centrosDeMunicipio =
  page.type === 'hub-municipio' && location ? getCentrosByMunicipio(location.slug).sort(ordenar) : [];
const centrosDeDisciplina =
  page.type === 'hub-disciplina' && discipline ? getCentrosByDisciplina(discipline.slug).sort(ordenar) : [];
---

<Layout
  title={page.meta.title}
  description={page.meta.description}
  canonical={`/${page.slug}/`}
  schema={[webPageSchema, breadcrumbSchema]}
>
  <Header />

  <!-- Breadcrumbs -->
  <nav aria-label="Migas de pan" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4 pb-0">
    <ol class="flex items-center gap-2 text-xs text-brand-muted">
      <li><a href="/" class="hover:text-white transition-colors">Inicio</a></li>
      {location && (
        <>
          <li class="text-brand-border">/</li>
          <li><a href={`/${location.slug}/`} class="hover:text-white transition-colors">{location.name}</a></li>
        </>
      )}
      {discipline && (
        <>
          <li class="text-brand-border">/</li>
          <li class="text-white">{discipline.nameEs}</li>
        </>
      )}
      {!discipline && !location && (
        <>
          <li class="text-brand-border">/</li>
          <li class="text-white">{page.h1}</li>
        </>
      )}
    </ol>
  </nav>

  <!-- Hero section -->
  <section class="relative overflow-hidden bg-brand-dark pt-10 pb-16 px-4">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-red/8 via-transparent to-transparent pointer-events-none" />
    <div class="max-w-7xl mx-auto relative">
      <div class="grid lg:grid-cols-2 gap-10 items-center">
        <div>
          {discipline && (
            <span class="inline-flex items-center gap-2 bg-brand-red/15 text-brand-red text-xs font-semibold px-3 py-1 rounded-full mb-4 border border-brand-red/30">
              <span>{discipline.emoji}</span>
              <span>{discipline.nameEs} · {location?.name ?? 'Comarca del Garraf'}</span>
            </span>
          )}
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white leading-tight mb-6">
            {page.h1}
          </h1>
          <p class="text-brand-muted leading-relaxed mb-8 text-lg">
            {page.intro}
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/contacto/" class="bg-brand-red hover:bg-red-700 text-white font-bold px-8 py-3 rounded-lg transition-colors text-center">
              Pedir orientación gratuita
            </a>
            <a href="/iniciacion/" class="flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white font-semibold px-8 py-3 rounded-lg border border-white/20 transition-colors">
              ¿Por dónde empiezo?
            </a>
          </div>
        </div>
        <!-- Info card: datos genéricos de la disciplina, sin inventar oferta local -->
        <div class="bg-brand-gray border border-brand-border rounded-2xl p-6 space-y-4">
          <h2 class="font-bold text-white text-lg mb-2">Resumen rápido</h2>
          {[
            { label: 'Zona', value: location?.name ?? 'Comarca del Garraf' },
            ...(discipline ? [
              { label: 'Disciplina', value: discipline.nameEs },
              { label: 'Ideal para', value: discipline.suitable.slice(0, 3).join(' · ') },
            ] : [
              { label: 'Disciplinas', value: 'Boxeo · Karate · MMA · BJJ y más' },
            ]),
            ...(discipline && location ? [
              {
                label: 'Centros en el directorio',
                value: centrosLocalDisciplina.length > 0
                  ? `${centrosLocalDisciplina.length} en ${location.nameShort}`
                  : `${centrosCercanosDisciplina.length} en municipios cercanos`,
              },
            ] : []),
            { label: 'Niveles', value: 'Desde iniciación absoluta' },
            { label: 'Orientación', value: '✓ Gratuita vía formulario' },
          ].map(row => (
            <div class="flex justify-between text-sm border-b border-brand-border pb-3 last:border-0 last:pb-0">
              <span class="text-brand-muted">{row.label}</span>
              <span class="text-white font-medium text-right max-w-[55%]">{row.value}</span>
            </div>
          ))}
          <a href="/contacto/" class="block w-full bg-brand-red hover:bg-red-700 text-white text-center font-bold py-3 rounded-lg transition-colors mt-2">
            Contactar →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  {discipline && (
    <section class="py-14 px-4 bg-brand-gray/30">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-2xl font-bold text-white mb-8 text-center">
          Qué aporta entrenar {discipline.nameEs}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {discipline.benefits.map((b, i) => (
            <div class="bg-brand-gray border border-brand-border rounded-xl p-5">
              <div class="w-8 h-8 rounded-lg bg-brand-red/20 text-brand-red text-sm font-bold flex items-center justify-center mb-3">
                {i + 1}
              </div>
              <p class="text-sm text-white font-medium">{b}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Cómo es la primera clase + equipación (contenido genérico honesto de la disciplina) -->
  {discipline && (page.type === 'money-page' || page.type === 'hub-disciplina') && (
    <section class="py-14 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-8">
          <div class="bg-brand-gray border border-brand-border rounded-2xl p-6">
            <h2 class="text-xl font-bold text-white mb-2">
              Cómo suele ser una primera clase de {discipline.nameEs}
            </h2>
            <p class="text-xs text-brand-muted mb-5">
              Cada centro tiene su propia dinámica; esto es lo habitual en la disciplina.
            </p>
            <ol class="space-y-3">
              {discipline.primeraClase.map((paso, i) => (
                <li class="flex gap-3 text-sm text-brand-muted leading-relaxed">
                  <span class="w-6 h-6 shrink-0 rounded-full bg-brand-red/20 text-brand-red text-xs font-bold flex items-center justify-center mt-0.5">
                    {i + 1}
                  </span>
                  <span>{paso}</span>
                </li>
              ))}
            </ol>
          </div>
          <div class="bg-brand-gray border border-brand-border rounded-2xl p-6">
            <h2 class="text-xl font-bold text-white mb-2">Equipación para empezar</h2>
            <p class="text-xs text-brand-muted mb-5">
              Sin marcas ni prisas: pregunta siempre en el centro antes de comprar nada.
            </p>
            <ul class="space-y-3">
              {discipline.equipacion.map(item => (
                <li class="flex gap-3 text-sm text-brand-muted leading-relaxed">
                  <span class="text-brand-red mt-0.5">✓</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Money page: centros reales que ofrecen la disciplina en el municipio -->
  {page.type === 'money-page' && discipline && location && (centrosLocalDisciplina.length > 0 || centrosCercanosDisciplina.length > 0) && (
    <section class="py-14 px-4">
      <div class="max-w-7xl mx-auto">
        {centrosLocalDisciplina.length > 0 ? (
          <>
            <h2 class="text-2xl font-bold text-white mb-2">
              Dónde practicar {discipline.nameEs} en {location.name}
            </h2>
            <p class="text-sm text-brand-muted mb-8 max-w-3xl">
              Centros de {location.name} que anuncian {discipline.nameEs} según fuentes públicas verificadas.
              Orden alfabético, sin valoraciones: comprueba horarios y condiciones directamente con cada centro.
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
              {centrosLocalDisciplina.map(c => <CentroCard centro={c} />)}
            </div>
          </>
        ) : (
          <>
            <h2 class="text-2xl font-bold text-white mb-2">
              {discipline.nameEs} cerca de {location.name}
            </h2>
            <p class="text-sm text-brand-muted mb-8 max-w-3xl">
              En nuestro directorio no consta por ahora ningún centro de {discipline.nameEs} con fuente pública
              verificable en {location.name}. Estas son las opciones más cercanas de la comarca:
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
              {centrosCercanosDisciplina.map(c => <CentroCard centro={c} showMunicipio />)}
            </div>
          </>
        )}
        <p class="mt-6 text-xs text-brand-muted">
          Ver el <a href="/centros/" class="text-brand-red hover:text-red-400">directorio completo de centros del Garraf</a> —
          si un dato ha cambiado o falta un centro, <a href="/contacto/" class="text-brand-red hover:text-red-400">avísanos</a>.
        </p>
      </div>
    </section>
  )}

  <!-- Hub municipio: list all disciplines available -->
  {page.type === 'hub-municipio' && location && (
    <section class="py-14 px-4">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-2xl font-bold text-white mb-8">
          Guías de disciplinas en {location.name}
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
          {allDisciplinesForLocation.map(p => {
            const d = getDisciplineBySlug(p.disciplina!);
            return d ? (
              <a
                href={`/${p.slug}/`}
                class="group bg-brand-gray border border-brand-border hover:border-brand-red/50 rounded-xl p-4 text-center transition-all"
              >
                <span class="text-2xl mb-2 block">{d.emoji}</span>
                <span class="text-sm font-semibold text-white group-hover:text-brand-red transition-colors">{d.nameEs}</span>
              </a>
            ) : null;
          })}
        </div>
      </div>
    </section>
  )}

  <!-- Hub disciplina: list all locations -->
  {page.type === 'hub-disciplina' && discipline && (
    <section class="py-14 px-4">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-2xl font-bold text-white mb-8">
          {discipline.nameEs} por municipios del Garraf
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {LOCATIONS.map(loc => {
            const moneyPage = ALL_PAGES.find(p => p.disciplina === discipline.slug && p.municipio === loc.slug);
            return moneyPage ? (
              <a
                href={`/${moneyPage.slug}/`}
                class="group bg-brand-gray border border-brand-border hover:border-brand-red/40 rounded-xl p-6 transition-all"
              >
                <h3 class="font-bold text-white group-hover:text-brand-red transition-colors mb-1">
                  {discipline.nameEs} en {loc.name}
                </h3>
                <p class="text-sm text-brand-muted">{loc.desc.split('.')[0]}.</p>
                <span class="text-xs text-brand-red mt-3 block">Ver guía →</span>
              </a>
            ) : (
              <div class="bg-brand-gray/50 border border-brand-border rounded-xl p-6">
                <h3 class="font-bold text-white mb-1">{discipline.nameEs} en {loc.name}</h3>
                <p class="text-sm text-brand-muted">Pregúntanos por las opciones en esta zona.</p>
                <a href="/contacto/" class="text-xs text-brand-red mt-3 block">Consultar →</a>
              </div>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- Hub municipio: centros reales del municipio -->
  {page.type === 'hub-municipio' && location && (
    <section class="py-14 px-4 bg-brand-gray/30">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-2xl font-bold text-white mb-2">
          Centros de artes marciales en {location.name}
        </h2>
        {centrosDeMunicipio.length > 0 ? (
          <>
            <p class="text-sm text-brand-muted mb-8 max-w-3xl">
              Centros del municipio con presencia pública verificable. Orden alfabético, sin valoraciones.
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
              {centrosDeMunicipio.map(c => <CentroCard centro={c} />)}
            </div>
          </>
        ) : (
          <p class="text-sm text-brand-muted mb-2 max-w-3xl">
            A fecha de la última verificación no nos consta ningún centro con fuente pública verificable en{' '}
            {location.name}. Los municipios vecinos ({(location.nearbyTowns ?? []).join(', ')}) y el resto de la
            comarca concentran la oferta más cercana.
          </p>
        )}
        <p class="mt-6 text-xs text-brand-muted">
          Ver el <a href="/centros/" class="text-brand-red hover:text-red-400">directorio completo del Garraf</a> —
          ¿falta un centro o hay un dato desactualizado? <a href="/contacto/" class="text-brand-red hover:text-red-400">Escríbenos</a>.
        </p>
      </div>
    </section>
  )}

  <!-- Hub disciplina: centros reales de la comarca que la ofrecen -->
  {page.type === 'hub-disciplina' && discipline && centrosDeDisciplina.length > 0 && (
    <section class="py-14 px-4 bg-brand-gray/30">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-2xl font-bold text-white mb-2">
          Dónde se practica {discipline.nameEs} en el Garraf
        </h2>
        <p class="text-sm text-brand-muted mb-8 max-w-3xl">
          Centros de la comarca que anuncian {discipline.nameEs} según fuentes públicas verificadas.
          Orden alfabético, sin valoraciones.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {centrosDeDisciplina.map(c => <CentroCard centro={c} showMunicipio />)}
        </div>
        <p class="mt-6 text-xs text-brand-muted">
          Ver el <a href="/centros/" class="text-brand-red hover:text-red-400">directorio completo del Garraf</a>.
        </p>
      </div>
    </section>
  )}

  <!-- Internal links: otras disciplinas en el mismo municipio -->
  {relatedByMunicipio.length > 0 && (
    <section class="py-12 px-4 bg-brand-gray/30">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-lg font-bold text-white mb-6">
          Más disciplinas en {location?.name}
        </h2>
        <div class="flex flex-wrap gap-3">
          {relatedByMunicipio.map(p => {
            const d = getDisciplineBySlug(p.disciplina!);
            return (
              <a
                href={`/${p.slug}/`}
                class="flex items-center gap-2 bg-brand-gray border border-brand-border hover:border-brand-red/40 rounded-lg px-4 py-2 text-sm text-brand-muted hover:text-white transition-all"
              >
                {d && <span>{d.emoji}</span>}
                {p.h1.replace('Clases de ', '')}
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- Internal links: misma disciplina en otros municipios -->
  {relatedByDisciplina.length > 0 && (
    <section class="py-10 px-4">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-lg font-bold text-white mb-6">
          {discipline?.nameEs} en otros municipios del Garraf
        </h2>
        <div class="flex flex-wrap gap-3">
          {relatedByDisciplina.map(p => {
            const l = getLocationBySlug(p.municipio!);
            return (
              <a
                href={`/${p.slug}/`}
                class="bg-brand-gray border border-brand-border hover:border-brand-red/40 rounded-lg px-4 py-2 text-sm text-brand-muted hover:text-white transition-all"
              >
                {discipline?.nameEs} en {l?.name ?? p.municipio}
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- Blog body content -->
  {page.type === 'blog' && page.body && (
    <section class="py-12 px-4">
      <div class="max-w-3xl mx-auto prose prose-invert prose-sm text-brand-muted leading-relaxed" set:html={page.body} />
    </section>
  )}

  <FAQ items={faqItems} title={`Preguntas frecuentes sobre ${discipline?.nameEs ?? 'artes marciales'} en ${location?.name ?? 'el Garraf'}`} />
  <ContactCTA disciplina={discipline?.nameEs} municipio={location?.name} />
  <Footer />
</Layout>
