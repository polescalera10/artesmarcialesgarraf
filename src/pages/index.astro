---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FAQ from '../components/FAQ.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { SITE } from '../data/site';
import { DISCIPLINES } from '../data/disciplines';
import { LOCATIONS } from '../data/locations';
import LineIcon from '../components/LineIcon.astro';

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Inicio", "item": SITE.url }],
};

const homeFAQ = [
  { q: '¿Qué es Artes Marciales Garraf?', a: 'Una guía independiente sobre artes marciales en la comarca del Garraf. Publicamos información por disciplina y municipio para ayudarte a decidir qué entrenar y cómo empezar. No somos un gimnasio ni una academia.' },
  { q: '¿Qué disciplinas cubre la guía?', a: 'Boxeo, karate, MMA, kickboxing, muay thai, Brazilian Jiu Jitsu, judo, taekwondo, defensa personal y krav maga, con guías específicas para niños, mujeres y adultos principiantes.' },
  { q: '¿Qué municipios cubre?', a: 'Toda la comarca del Garraf: Sitges, Vilanova i la Geltrú, Sant Pere de Ribes, Cubelles y Canyelles, además de referencias a municipios cercanos.' },
  { q: '¿Cómo elijo mi primera arte marcial?', a: 'Depende de tu objetivo: para ponerte en forma, boxeo o kickboxing; para niños, karate, judo o taekwondo; para autodefensa práctica, defensa personal o krav maga; para trabajo de suelo y técnica, BJJ. En cada guía de disciplina te explicamos para quién es adecuada.' },
  { q: '¿Cuánto cuesta apuntarse a artes marciales?', a: 'Cada centro fija sus propias tarifas y cambian con el tiempo, por eso no publicamos precios. Antes de apuntarte, pregunta siempre por matrícula, permanencia y si ofrecen clase de prueba.' },
  { q: '¿Me podéis ayudar a encontrar clase?', a: 'Sí. Escríbenos por el formulario de contacto contándonos qué buscas (disciplina, municipio, edad, objetivo) y te orientamos sin coste.' },
];
---

<Layout
  title="Artes Marciales en el Garraf | Guía de Sitges y Vilanova"
  description="Guía de artes marciales en la comarca del Garraf: boxeo, karate, MMA, muay thai, BJJ, judo, taekwondo y defensa personal en Sitges, Vilanova i la Geltrú y alrededores."
  schema={breadcrumb}
>
  <Header />

  <!-- Hero -->
  <section class="relative overflow-hidden bg-brand-dark pt-16 pb-24 px-4">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-red/10 via-transparent to-transparent pointer-events-none" />
    <div class="max-w-7xl mx-auto relative">
      <div class="max-w-3xl">
        <span class="inline-block bg-brand-red/15 text-brand-red text-xs font-semibold px-3 py-1 rounded-full mb-6 uppercase tracking-wider border border-brand-red/30">
          Guía independiente · Comarca del Garraf
        </span>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-tight mb-6">
          Artes Marciales<br />
          <span class="text-brand-red">en el Garraf</span>
        </h1>
        <p class="text-lg text-brand-muted mb-8 max-w-xl leading-relaxed">
          La guía para empezar a entrenar en Sitges, Vilanova i la Geltrú y toda la comarca. Descubre qué disciplina encaja contigo —boxeo, karate, MMA, muay thai, BJJ, judo, taekwondo o defensa personal— y da el primer paso con criterio.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contacto/" class="bg-brand-red hover:bg-red-700 text-white font-bold px-8 py-4 rounded-lg transition-colors text-center text-lg">
            Pedir orientación gratuita
          </a>
          <a href="/iniciacion/" class="flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white font-semibold px-8 py-4 rounded-lg transition-colors border border-white/20">
            ¿Por dónde empiezo?
          </a>
        </div>
        <!-- Señales honestas -->
        <div class="flex flex-wrap gap-6 mt-10 text-sm text-brand-muted">
          <span class="flex items-center gap-2"><span class="text-brand-red">●</span> 10 disciplinas explicadas</span>
          <span class="flex items-center gap-2"><span class="text-brand-red">●</span> 5 municipios del Garraf</span>
          <span class="flex items-center gap-2"><span class="text-brand-red">●</span> Guías para niños, mujeres y adultos</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Disciplinas grid -->
  <section class="py-16 px-4 bg-brand-gray/30">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-2xl font-bold text-white mb-2">Elige tu disciplina</h2>
        <p class="text-brand-muted">10 artes marciales explicadas: qué son, para quién y cómo empezar</p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
        {DISCIPLINES.map(d => (
          <a
            href={`/${d.slug}/`}
            class="group bg-brand-gray border border-brand-border hover:border-brand-red/50 rounded-xl p-4 text-center transition-all hover:-translate-y-0.5"
          >
            <LineIcon name={d.slug} class="w-8 h-8 text-brand-red mx-auto mb-2" />
            <span class="text-sm font-semibold text-white group-hover:text-brand-red transition-colors">{d.nameEs}</span>
            <p class="text-xs text-brand-muted mt-1 leading-tight hidden sm:block line-clamp-2">{d.shortDesc.split('.')[0]}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Municipios -->
  <section class="py-16 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-2xl font-bold text-white mb-2">Toda la comarca del Garraf</h2>
        <p class="text-brand-muted">Guías por municipio: qué disciplinas buscar y cómo empezar en tu zona.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {LOCATIONS.filter(l => l.priority <= 2).map(l => (
          <a href={`/${l.slug}/`} class="group bg-brand-gray border border-brand-border hover:border-brand-red/40 rounded-xl p-6 transition-all">
            <div class="flex items-center justify-between mb-3">
              <h3 class="font-bold text-white group-hover:text-brand-red transition-colors">{l.name}</h3>
            </div>
            <p class="text-sm text-brand-muted line-clamp-3">{l.desc}</p>
            <span class="text-xs text-brand-red mt-3 block group-hover:underline">Ver guía →</span>
          </a>
        ))}
        <div class="bg-brand-gray/50 border border-brand-border rounded-xl p-6">
          <h3 class="font-bold text-white mb-3">También cerca de ti</h3>
          <div class="flex flex-wrap gap-2">
            {['Sant Pere de Ribes', 'Cubelles', 'Canyelles', 'Olivella', 'Castelldefels'].map(t => (
              <span class="text-xs bg-brand-border text-brand-muted px-3 py-1 rounded-full">{t}</span>
            ))}
          </div>
          <p class="text-sm text-brand-muted mt-3">Si vives en un municipio pequeño, en las guías te indicamos las zonas con más oferta cercana.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Qué encontrarás en la guía -->
  <section class="py-16 px-4 bg-brand-gray/30">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-2xl font-bold text-white mb-2">Qué encontrarás en esta guía</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { icon: 'brujula', title: 'Orientación por disciplina', desc: 'Qué es cada arte marcial, qué beneficios tiene, para quién es adecuada y qué esperar de las primeras clases.' },
          { icon: 'mapa-pin', title: 'Información por municipio', desc: 'Guías locales para Sitges, Vilanova i la Geltrú, Sant Pere de Ribes, Cubelles y Canyelles.' },
          { icon: 'personas', title: 'Guías por perfil', desc: 'Contenido específico para niños, mujeres, adultos principiantes y quienes buscan defensa personal.' },
          { icon: 'check-circulo', title: 'Criterios para elegir centro', desc: 'Qué preguntar antes de apuntarte: titulación de instructores, tamaño de grupos, permanencia, clase de prueba.' },
          { icon: 'sobre', title: 'Orientación personalizada', desc: 'Escríbenos qué buscas y te ayudamos a dar el primer paso, sin coste y sin compromiso.' },
          { icon: 'balanza', title: 'Sin humo', desc: 'Guía independiente: no publicamos reseñas infladas ni datos que no podamos sostener. Solo información útil.' },
        ].map(item => (
          <div class="bg-brand-gray border border-brand-border rounded-xl p-6">
            <LineIcon name={item.icon} class="w-8 h-8 text-brand-red mb-3" />
            <h3 class="font-bold text-white mb-2">{item.title}</h3>
            <p class="text-sm text-brand-muted leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FAQ items={homeFAQ} />
  <ContactCTA />
  <Footer />
</Layout>
