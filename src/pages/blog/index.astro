---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import { ALL_PAGES } from '../../data/pages';
import { SITE } from '../../data/site';

const title = 'Blog: Guías y Comparativas de Artes Marciales en el Garraf';
const description =
  'Guías largas y comparativas para decidir con criterio: qué arte marcial elegir para tu hijo, cómo empezar de adulto, dónde aprender boxeo y qué funciona en defensa personal. Escritas para la comarca del Garraf.';

const posts = ALL_PAGES
  .filter(p => p.type === 'blog')
  .sort((a, b) => (b.fecha ?? '').localeCompare(a.fecha ?? '') || a.h1.localeCompare(b.h1, 'es'));

const listSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  url: `${SITE.url}/blog/`,
  inLanguage: 'es',
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: posts.length,
    itemListElement: posts.map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${SITE.url}/${p.slug}/`,
      name: p.h1,
    })),
  },
};

const formatearFecha = (iso?: string) =>
  iso ? new Date(iso).toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' }) : null;
---

<Layout title={title} description={description} canonical="/blog/" schema={[listSchema]}>
  <Header />

  <section class="relative overflow-hidden bg-brand-dark pt-12 pb-10 px-4">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-red/8 via-transparent to-transparent pointer-events-none" />
    <div class="max-w-7xl mx-auto relative">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white leading-tight mb-5">
        Guías y comparativas
      </h1>
      <p class="text-brand-muted leading-relaxed text-lg max-w-3xl">
        Artículos largos para las decisiones que más dudas generan: qué disciplina elegir para tu hijo,
        cómo empezar de adulto, qué funciona de verdad en defensa personal. Sin publicidad de centros y
        con la misma regla que el resto de la web: solo información honesta.
      </p>
    </div>
  </section>

  <section class="py-12 px-4">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">
      {posts.map(p => (
        <a
          href={`/${p.slug}/`}
          class="group bg-brand-gray border border-brand-border hover:border-brand-red/40 rounded-xl p-6 flex flex-col gap-3 transition-all"
        >
          <h2 class="text-lg font-bold text-white leading-snug group-hover:text-brand-red transition-colors">
            {p.h1}
          </h2>
          <p class="text-sm text-brand-muted leading-relaxed">{p.meta.description}</p>
          <div class="mt-auto pt-2 flex items-center justify-between text-xs text-brand-muted">
            {p.fecha && <time datetime={p.fecha}>{formatearFecha(p.fecha)}</time>}
            <span class="text-brand-red font-semibold">Leer la guía →</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="px-4 pb-4">
    <div class="max-w-7xl mx-auto">
      <div class="bg-brand-gray/60 border border-brand-border rounded-xl px-5 py-4 text-sm text-brand-muted leading-relaxed">
        ¿Buscas un centro en lugar de una guía? Consulta el
        <a href="/centros/" class="text-brand-red hover:text-red-400">directorio de centros verificado del Garraf</a>
        o las guías por <a href="/vilanova-i-la-geltru/" class="text-brand-red hover:text-red-400">municipio</a> y
        <a href="/iniciacion/" class="text-brand-red hover:text-red-400">disciplina</a>.
      </div>
    </div>
  </section>

  <ContactCTA />
  <Footer />
</Layout>
