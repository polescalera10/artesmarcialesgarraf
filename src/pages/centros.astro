---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { CENTROS, FUENTE_LABELS, getCentrosByMunicipio } from '../data/centros';
import { DISCIPLINES, getDisciplineBySlug } from '../data/disciplines';
import { LOCATIONS } from '../data/locations';
import { SITE } from '../data/site';

const title = 'Centros de Artes Marciales en el Garraf | Directorio Verificado';
const description =
  'Directorio de centros reales de artes marciales en el Garraf: Sitges, Vilanova i la Geltrú, Sant Pere de Ribes y Cubelles. Datos de fuentes públicas verificadas, sin valoraciones ni publicidad.';

const totalCentros = CENTROS.length;
const fechaVerificacion = CENTROS.reduce((max, c) => (c.verificado > max ? c.verificado : max), '');

// Schema honesto: ItemList de organizaciones reales, sin ratings ni reviews.
const listSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  url: `${SITE.url}/centros/`,
  inLanguage: 'es',
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: totalCentros,
    itemListElement: CENTROS.map((c, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'SportsClub',
        name: c.nombre,
        ...(c.web ? { url: c.web } : {}),
        ...(c.direccion ? { address: c.direccion } : {}),
      },
    })),
  },
};
---

<Layout title={title} description={description} canonical="/centros/" schema={[listSchema]}>
  <Header />

  <section class="relative overflow-hidden bg-brand-dark pt-12 pb-10 px-4">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-red/8 via-transparent to-transparent pointer-events-none" />
    <div class="max-w-7xl mx-auto relative">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white leading-tight mb-5">
        Centros de Artes Marciales en el Garraf
      </h1>
      <p class="text-brand-muted leading-relaxed text-lg max-w-3xl">
        Directorio de centros, clubs y academias de artes marciales de la comarca con presencia pública
        verificable. Sin valoraciones, sin rankings y sin publicidad: solo el nombre, las disciplinas que
        cada centro anuncia y su fuente pública, para que compruebes y elijas por ti mismo.
      </p>
      <div class="mt-6 inline-flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-brand-muted bg-brand-gray border border-brand-border rounded-xl px-5 py-3">
        <span><strong class="text-white">{totalCentros}</strong> centros listados</span>
        <span>Última verificación de fuentes: <strong class="text-white">{fechaVerificacion}</strong></span>
      </div>
    </div>
  </section>

  <!-- Transparencia del directorio -->
  <section class="px-4">
    <div class="max-w-7xl mx-auto">
      <div class="bg-brand-gray/60 border border-brand-border rounded-xl px-5 py-4 text-sm text-brand-muted leading-relaxed">
        <strong class="text-white">Cómo se construye este directorio:</strong> cada ficha procede de una fuente
        pública (web del propio centro, registro de clubs de su federación o directorio municipal de entidades) y
        muestra únicamente datos que constan en esa fuente en la fecha de verificación. El orden dentro de cada
        municipio es alfabético. No cobramos por aparecer y no publicamos opiniones ni reseñas. Si un dato ha
        cambiado o tu centro no aparece, <a href="/contacto/" class="text-brand-red hover:text-red-400">escríbenos</a> y
        lo corregimos o añadimos con su fuente.
      </div>
    </div>
  </section>

  {LOCATIONS.map(loc => {
    const centros = getCentrosByMunicipio(loc.slug).sort((a, b) => a.nombre.localeCompare(b.nombre, 'es'));
    return (
      <section class="py-10 px-4">
        <div class="max-w-7xl mx-auto">
          <div class="flex items-baseline justify-between flex-wrap gap-2 mb-6">
            <h2 class="text-2xl font-bold text-white">{loc.name}</h2>
            <a href={`/${loc.slug}/`} class="text-sm text-brand-red hover:text-red-400 transition-colors">
              Guía de artes marciales en {loc.nameShort} →
            </a>
          </div>

          {centros.length === 0 ? (
            <div class="bg-brand-gray/50 border border-brand-border rounded-xl p-6 text-sm text-brand-muted leading-relaxed">
              A fecha de la última verificación no nos consta ningún centro de artes marciales con fuente pública
              verificable en {loc.name}.
              {loc.nearbyTowns && (
                <> Las opciones más cercanas están en los municipios vecinos de la comarca — consulta el resto del directorio en esta página.</>
              )}
              {' '}¿Conoces uno? <a href="/contacto/" class="text-brand-red hover:text-red-400">Dínoslo</a> y lo añadimos.
            </div>
          ) : (
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
              {centros.map(c => (
                <div class="bg-brand-gray border border-brand-border rounded-xl p-5 flex flex-col gap-3">
                  <h3 class="font-bold text-white leading-snug">{c.nombre}</h3>

                  <div class="flex flex-wrap gap-1.5">
                    {c.disciplinas.map(slug => {
                      const d = getDisciplineBySlug(slug);
                      return d ? (
                        <a
                          href={`/${d.slug}/`}
                          class="inline-flex items-center gap-1 bg-brand-dark border border-brand-border hover:border-brand-red/40 rounded-full px-2.5 py-0.5 text-xs text-brand-muted hover:text-white transition-colors"
                        >
                          <span>{d.emoji}</span>{d.nameEs}
                        </a>
                      ) : null;
                    })}
                    {(c.otras ?? []).map(o => (
                      <span class="inline-flex items-center bg-brand-dark/60 border border-brand-border rounded-full px-2.5 py-0.5 text-xs text-brand-muted/80">
                        {o}
                      </span>
                    ))}
                  </div>

                  {c.direccion && <p class="text-xs text-brand-muted">{c.direccion}</p>}

                  <div class="mt-auto pt-2 border-t border-brand-border flex items-center justify-between gap-2">
                    {c.web ? (
                      <a
                        href={c.web}
                        target="_blank"
                        rel="noopener noreferrer nofollow"
                        class="text-xs font-semibold text-brand-red hover:text-red-400 transition-colors"
                      >
                        Ver web del centro ↗
                      </a>
                    ) : (
                      <span class="text-xs text-brand-muted/70">Sin web propia conocida</span>
                    )}
                    <a
                      href={c.fuente}
                      target="_blank"
                      rel="noopener noreferrer nofollow"
                      class="text-[11px] text-brand-muted/70 hover:text-brand-muted transition-colors"
                      title={`Fuente: ${FUENTE_LABELS[c.fuenteTipo]} (verificado ${c.verificado})`}
                    >
                      Fuente: {FUENTE_LABELS[c.fuenteTipo]}
                    </a>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      </section>
    );
  })}

  <!-- Disciplinas de la guía -->
  <section class="py-10 px-4 bg-brand-gray/30">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-lg font-bold text-white mb-6">¿No sabes qué disciplina elegir?</h2>
      <div class="flex flex-wrap gap-3">
        {DISCIPLINES.map(d => (
          <a
            href={`/${d.slug}/`}
            class="flex items-center gap-2 bg-brand-gray border border-brand-border hover:border-brand-red/40 rounded-lg px-4 py-2 text-sm text-brand-muted hover:text-white transition-all"
          >
            <span>{d.emoji}</span>{d.nameEs}
          </a>
        ))}
      </div>
    </div>
  </section>

  <ContactCTA />
  <Footer />
</Layout>
