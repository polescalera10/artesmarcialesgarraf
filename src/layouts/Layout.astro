---
import { SITE } from '../data/site';
// Inter self-hosted (@fontsource): sin peticiones a Google Fonts — mejor
// rendimiento y sin cesión de IPs a terceros (RGPD post-Schrems II).
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/inter/800.css';
import '@fontsource/inter/900.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: object | object[];
  noindex?: boolean;
}

const {
  title,
  description,
  canonical = Astro.url.pathname,
  ogImage = `${SITE.url}/og-default.png`,
  schema,
  noindex = false,
} = Astro.props;

const canonicalUrl = `${SITE.url}${canonical.endsWith('/') ? canonical : canonical + '/'}`;
const schemaArray = schema ? (Array.isArray(schema) ? schema : [schema]) : [];

// Analítica Plausible (B1): solo se emite si Pol define PUBLIC_PLAUSIBLE_DOMAIN
// en Vercel (p. ej. "artesmarcialesgarraf.vercel.app"). Plausible no usa
// cookies ni identifica usuarios → no requiere banner de consentimiento (B2);
// la política de privacidad ya recoge este caso condicionalmente.
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="es_ES" />
  <meta property="og:site_name" content={SITE.name} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Geo tags for local SEO -->
  <meta name="geo.region" content="ES-B" />
  <meta name="geo.placename" content="Garraf, Barcelona" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  {plausibleDomain && (
    <script defer data-domain={plausibleDomain} src="https://plausible.io/js/script.js"></script>
  )}

  <!-- Schema JSON-LD -->
  {schemaArray.map(s => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}

  <!-- Global WebSite schema (marca neutra: guía local, sin NAP de negocio) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": SITE.name,
    "alternateName": SITE.tagline,
    "url": SITE.url,
    "inLanguage": "es",
    "about": {
      "@type": "Thing",
      "name": "Artes marciales en la comarca del Garraf (Barcelona)",
    },
  })} />
</head>
<body class="bg-brand-dark text-white font-sans antialiased">
  <slot />
  <style is:global>
    @media (prefers-reduced-motion: no-preference) {
      html { scroll-behavior: smooth; }
    }
  </style>
</body>
</html>
