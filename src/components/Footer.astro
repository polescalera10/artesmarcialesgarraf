---
import { SITE } from '../data/site';
import { DISCIPLINES } from '../data/disciplines';
import { LOCATIONS } from '../data/locations';

const year = new Date().getFullYear();
---

<footer class="bg-brand-gray border-t border-brand-border mt-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-brand-red font-black text-2xl">AM</span>
          <span class="font-bold text-white">Academia<br /><span class="text-brand-muted font-normal text-sm">Artes Marciales Garraf</span></span>
        </div>
        <p class="text-sm text-brand-muted leading-relaxed mb-4">
          El centro de referencia de artes marciales en la comarca del Garraf. Clases para todas las edades y niveles en Sitges y Vilanova i la Geltrú.
        </p>
        <div class="flex gap-3">
          <a href={SITE.social.instagram} target="_blank" rel="noopener noreferrer"
             class="w-8 h-8 rounded bg-brand-border flex items-center justify-center text-brand-muted hover:text-white transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href={SITE.social.facebook} target="_blank" rel="noopener noreferrer"
             class="w-8 h-8 rounded bg-brand-border flex items-center justify-center text-brand-muted hover:text-white transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Disciplinas -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Disciplinas</h3>
        <ul class="space-y-2">
          {DISCIPLINES.slice(0, 8).map(d => (
            <li>
              <a href={`/${d.slug}/`} class="text-sm text-brand-muted hover:text-white transition-colors">
                {d.nameEs}
              </a>
            </li>
          ))}
          <li>
            <a href="/defensa-personal/" class="text-sm text-brand-muted hover:text-white transition-colors">Defensa Personal</a>
          </li>
        </ul>
      </div>

      <!-- Municipios -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Localidades</h3>
        <ul class="space-y-2">
          {LOCATIONS.map(l => (
            <li>
              <a href={`/${l.slug}/`} class="text-sm text-brand-muted hover:text-white transition-colors">
                {l.name}
              </a>
            </li>
          ))}
          <li class="pt-1 border-t border-brand-border">
            <a href="/clases-para-ninos/" class="text-sm text-brand-muted hover:text-white transition-colors">Clases para Niños</a>
          </li>
          <li>
            <a href="/clases-para-mujeres/" class="text-sm text-brand-muted hover:text-white transition-colors">Clases para Mujeres</a>
          </li>
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Contacto</h3>
        <ul class="space-y-3">
          <li class="flex gap-2">
            <svg class="w-4 h-4 text-brand-red mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span class="text-sm text-brand-muted">{SITE.address.street}<br />{SITE.address.city}, {SITE.address.province}</span>
          </li>
          <li class="flex gap-2">
            <svg class="w-4 h-4 text-brand-red mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
            </svg>
            <a href={`tel:${SITE.phone}`} class="text-sm text-brand-muted hover:text-white transition-colors">{SITE.phone}</a>
          </li>
          <li class="flex gap-2">
            <svg class="w-4 h-4 text-brand-red mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href={`mailto:${SITE.email}`} class="text-sm text-brand-muted hover:text-white transition-colors">{SITE.email}</a>
          </li>
          <li class="pt-1">
            {SITE.hours.map(h => (
              <div class="text-sm text-brand-muted">{h.day}: <span class="text-white">{h.time}</span></div>
            ))}
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-brand-border flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-brand-muted">
        © {year} {SITE.name}. Todos los derechos reservados.
      </p>
      <div class="flex gap-4">
        <a href="/aviso-legal/" class="text-xs text-brand-muted hover:text-white transition-colors">Aviso legal</a>
        <a href="/politica-privacidad/" class="text-xs text-brand-muted hover:text-white transition-colors">Privacidad</a>
        <a href="/sitemap.xml" class="text-xs text-brand-muted hover:text-white transition-colors">Sitemap</a>
      </div>
    </div>
  </div>
</footer>
