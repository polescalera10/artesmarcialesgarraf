---
import { SITE } from '../data/site';
import { DISCIPLINES } from '../data/disciplines';
import { LOCATIONS } from '../data/locations';

const year = new Date().getFullYear();
---

<footer class="bg-brand-gray border-t border-brand-border mt-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-brand-red font-black text-2xl">AM</span>
          <span class="font-bold text-white">Artes Marciales Garraf<br /><span class="text-brand-muted font-normal text-sm">La guía de la comarca</span></span>
        </div>
        <p class="text-sm text-brand-muted leading-relaxed">
          Guía independiente de artes marciales en la comarca del Garraf. Información por disciplina y municipio para ayudarte a empezar a entrenar en Sitges, Vilanova i la Geltrú y alrededores.
        </p>
      </div>

      <!-- Disciplinas -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Disciplinas</h3>
        <ul class="space-y-2">
          {DISCIPLINES.slice(0, 8).map(d => (
            <li>
              <a href={`/${d.slug}/`} class="text-sm text-brand-muted hover:text-white transition-colors">
                {d.nameEs}
              </a>
            </li>
          ))}
          <li>
            <a href="/defensa-personal/" class="text-sm text-brand-muted hover:text-white transition-colors">Defensa Personal</a>
          </li>
        </ul>
      </div>

      <!-- Municipios -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Localidades</h3>
        <ul class="space-y-2">
          {LOCATIONS.map(l => (
            <li>
              <a href={`/${l.slug}/`} class="text-sm text-brand-muted hover:text-white transition-colors">
                {l.name}
              </a>
            </li>
          ))}
          <li class="pt-1 border-t border-brand-border">
            <a href="/centros/" class="text-sm text-brand-muted hover:text-white transition-colors">Directorio de centros</a>
          </li>
          <li>
            <a href="/clases-para-ninos/" class="text-sm text-brand-muted hover:text-white transition-colors">Clases para Niños</a>
          </li>
          <li>
            <a href="/clases-para-mujeres/" class="text-sm text-brand-muted hover:text-white transition-colors">Clases para Mujeres</a>
          </li>
          <li>
            <a href="/blog/" class="text-sm text-brand-muted hover:text-white transition-colors">Blog: guías y comparativas</a>
          </li>
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Contacto</h3>
        <ul class="space-y-3">
          <li class="flex gap-2">
            <svg class="w-4 h-4 text-brand-red mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href={`mailto:${SITE.email}`} class="text-sm text-brand-muted hover:text-white transition-colors">{SITE.email}</a>
          </li>
          <li>
            <a href="/contacto/" class="text-sm text-brand-red hover:text-red-400 transition-colors">Formulario de contacto →</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-brand-border flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-brand-muted">
        © {year} {SITE.name}. Guía independiente — no somos un gimnasio ni una academia.
      </p>
      <div class="flex gap-4">
        <a href="/aviso-legal/" class="text-xs text-brand-muted hover:text-white transition-colors">Aviso legal</a>
        <a href="/politica-privacidad/" class="text-xs text-brand-muted hover:text-white transition-colors">Privacidad</a>
        <a href="/sitemap.xml" class="text-xs text-brand-muted hover:text-white transition-colors">Sitemap</a>
      </div>
    </div>
  </div>
</footer>
