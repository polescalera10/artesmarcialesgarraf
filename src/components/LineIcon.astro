---
// Iconografía propia del sitio (C4): iconos de línea originales dibujados a
// mano para este proyecto — sin dependencia de sets de terceros ni licencias.
// Son decorativos (aria-hidden): la palabra clave la lleva siempre el texto
// que los acompaña. `name` admite el slug de disciplina o un nombre genérico.
interface Props {
  name: string;
  class?: string;
}
const { name, class: className = 'w-4 h-4' } = Astro.props;

const ICONS: Record<string, string> = {
  // ── Disciplinas ──────────────────────────────────────────────────────────
  // Guante de boxeo
  'boxeo': '<path d="M6 10a6 6 0 0 1 12 0v3a5 5 0 0 1-5 5h-2a5 5 0 0 1-5-5z"/><path d="M9 18v2.5h6V18"/><path d="M6 11H5a2 2 0 0 0 0 4h1"/><path d="M10 10h4"/>',
  // Cinturón anudado (karategi)
  'karate': '<path d="M3 9.5h7M14 9.5h7M3 13.5h7M14 13.5h7"/><rect x="10" y="9.5" width="4" height="4"/><path d="M10.5 13.5 8.5 20M13.5 13.5l2 6.5"/>',
  // Octágono (jaula de MMA)
  'mma': '<path d="M8.5 3h7l5.5 5.5v7L15.5 21h-7L3 15.5v-7z"/><circle cx="12" cy="12" r="2.5"/>',
  // Trayectoria de patada
  'kickboxing': '<path d="M4 20C11 18 15.5 12.5 16.8 5.5"/><path d="M13.5 6.5 17 4.5l1.5 3.5"/>',
  // Ocho extremidades (estrella de 8 puntas)
  'muay-thai': '<path d="M12 3v4M12 17v4M3 12h4M17 12h4M5.6 5.6l2.9 2.9M15.5 15.5l2.9 2.9M18.4 5.6l-2.9 2.9M8.5 15.5l-2.9 2.9"/>',
  // Agarre: eslabones enlazados (grappling)
  'jiu-jitsu-brasileno': '<rect x="7" y="3.5" width="10" height="8" rx="4"/><rect x="7" y="12.5" width="10" height="8" rx="4"/><path d="M12 8.5v7"/>',
  // Proyección: flecha circular
  'judo': '<path d="M20 12a8 8 0 1 1-2.5-5.8"/><path d="M17.8 3v3.5h3.5"/>',
  // Taegeuk coreano
  'taekwondo': '<circle cx="12" cy="12" r="8.5"/><path d="M12 3.5a4.25 4.25 0 0 1 0 8.5 4.25 4.25 0 0 0 0 8.5"/>',
  // Escudo con check
  'defensa-personal': '<path d="M12 3l8 3v6c0 4.8-3.4 8-8 9-4.6-1-8-4.2-8-9V6z"/><path d="m9 12 2 2 4-4.5"/>',
  // Escudo con rayo
  'krav-maga': '<path d="M12 3l8 3v6c0 4.8-3.4 8-8 9-4.6-1-8-4.2-8-9V6z"/><path d="M13 7.5 9.5 12.5H13L10.5 17"/>',
  // ── Genéricos ────────────────────────────────────────────────────────────
  'brujula': '<circle cx="12" cy="12" r="9"/><path d="m15.5 8.5-2 5-5 2 2-5z"/>',
  'mapa-pin': '<path d="M12 21s-7-5.5-7-11a7 7 0 0 1 14 0c0 5.5-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/>',
  'personas': '<circle cx="9" cy="8" r="3"/><path d="M3.5 20c0-3 2.5-5 5.5-5s5.5 2 5.5 5"/><path d="M16 5.5a3 3 0 0 1 0 5.5M17.5 15.5c1.8.7 3 2.3 3 4.5"/>',
  'check-circulo': '<circle cx="12" cy="12" r="9"/><path d="m8 12.5 2.5 2.5L16 9.5"/>',
  'sobre': '<rect x="3" y="5.5" width="18" height="13" rx="2"/><path d="m3.5 7 8.5 6 8.5-6"/>',
  'balanza': '<path d="M12 4v16M8 20h8"/><path d="M12 6H6.5L4 12h5zM12 6h5.5L20 12h-5z"/><path d="M4 12a2.5 2.5 0 0 0 5 0M15 12a2.5 2.5 0 0 0 5 0"/>',
};

const paths = ICONS[name] ?? ICONS['check-circulo'];
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={paths}
/>
