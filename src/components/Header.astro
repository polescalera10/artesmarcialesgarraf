---
import { SITE } from '../data/site';

const nav = [
  { label: 'Disciplinas', href: '/boxeo/' },
  { label: 'Sitges', href: '/sitges/' },
  { label: 'Vilanova', href: '/vilanova-i-la-geltru/' },
  { label: 'Niños', href: '/clases-para-ninos/' },
  { label: 'Mujeres', href: '/clases-para-mujeres/' },
  { label: 'Sobre nosotros', href: '/sobre-nosotros/' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-brand-dark/95 backdrop-blur border-b border-brand-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 shrink-0">
        <span class="text-brand-red font-black text-xl tracking-tight">AM</span>
        <span class="font-bold text-white text-sm leading-tight hidden sm:block">
          Academia<br />
          <span class="text-brand-muted font-normal">Artes Marciales Garraf</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {nav.map(item => (
          <a
            href={item.href}
            class:list={[
              'px-3 py-2 text-sm rounded-md transition-colors',
              currentPath === item.href
                ? 'text-white bg-brand-gray'
                : 'text-brand-muted hover:text-white hover:bg-brand-gray/50',
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- CTA -->
      <div class="flex items-center gap-3">
        <a
          href={`https://wa.me/${SITE.whatsapp}?text=Hola,%20me%20interesa%20información%20sobre%20las%20clases`}
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:flex items-center gap-1.5 text-sm text-brand-muted hover:text-white transition-colors"
        >
          <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>
        <a
          href="/contacto/"
          class="bg-brand-red hover:bg-red-700 text-white text-sm font-semibold px-4 py-2 rounded-md transition-colors"
        >
          Clase gratis
        </a>
        <!-- Mobile menu button -->
        <button
          id="menu-toggle"
          class="lg:hidden p-2 text-brand-muted hover:text-white"
          aria-label="Abrir menú"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-brand-border bg-brand-gray">
    <nav class="px-4 py-3 flex flex-col gap-1">
      {nav.map(item => (
        <a
          href={item.href}
          class="px-3 py-2 text-sm text-brand-muted hover:text-white hover:bg-brand-border rounded-md transition-colors"
        >
          {item.label}
        </a>
      ))}
      <a
        href={`https://wa.me/${SITE.whatsapp}`}
        target="_blank"
        rel="noopener noreferrer"
        class="px-3 py-2 text-sm text-green-400 hover:text-green-300 transition-colors"
      >
        WhatsApp: {SITE.phone}
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
