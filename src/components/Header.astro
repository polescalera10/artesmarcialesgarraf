---
import { DISCIPLINES } from '../data/disciplines';
import { LOCATIONS } from '../data/locations';
import LineIcon from './LineIcon.astro';

const currentPath = Astro.url.pathname;

const paraTi = [
  { label: 'Niños', href: '/clases-para-ninos/' },
  { label: 'Mujeres', href: '/clases-para-mujeres/' },
  { label: 'Adultos', href: '/clases-para-adultos/' },
  { label: 'No sé por dónde empezar', href: '/iniciacion/' },
  { label: 'Guías y comparativas (blog)', href: '/blog/' },
];

const isActive = (href: string) => currentPath === href;
const isDisciplina = DISCIPLINES.some(d => currentPath === `/${d.slug}/`);
const isMunicipio = LOCATIONS.some(l => currentPath === `/${l.slug}/`);
const isParaTi = paraTi.some(p => currentPath === p.href);

const linkBase = 'px-3 py-2 text-sm rounded-md transition-colors';
const linkActive = 'text-white bg-brand-gray';
const linkIdle = 'text-brand-muted hover:text-white hover:bg-brand-gray/50';
---

<a
  href="#contenido"
  class="sr-only focus:not-sr-only focus:absolute focus:z-[60] focus:top-2 focus:left-2 focus:bg-brand-red focus:text-white focus:px-4 focus:py-2 focus:rounded-md focus:text-sm focus:font-semibold"
>
  Saltar al contenido
</a>

<header class="sticky top-0 z-50 bg-brand-dark/95 backdrop-blur border-b border-brand-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 shrink-0" aria-label="Artes Marciales Garraf — inicio">
        <span class="text-brand-red font-black text-xl tracking-tight">AM</span>
        <span class="font-bold text-white text-sm leading-tight hidden sm:block">
          Artes Marciales Garraf<br />
          <span class="text-brand-muted font-normal">La guía de la comarca</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Navegación principal">
        <a href="/centros/" class:list={[linkBase, isActive('/centros/') ? linkActive : linkIdle]}>
          Centros
        </a>

        <!-- Dropdown: Disciplinas -->
        <div class="relative" data-dropdown>
          <button
            type="button"
            class:list={[linkBase, 'inline-flex items-center gap-1', isDisciplina ? linkActive : linkIdle]}
            aria-expanded="false"
            aria-haspopup="true"
            data-dropdown-toggle
          >
            Disciplinas
            <svg class="w-3.5 h-3.5 transition-transform" data-dropdown-chevron fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div
            class="hidden absolute left-0 top-full mt-1 w-[420px] bg-brand-gray border border-brand-border rounded-xl shadow-xl shadow-black/40 p-2 grid grid-cols-2 gap-0.5"
            data-dropdown-panel
          >
            {DISCIPLINES.map(d => (
              <a
                href={`/${d.slug}/`}
                class:list={[
                  'flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm transition-colors',
                  isActive(`/${d.slug}/`) ? 'text-white bg-brand-border' : 'text-brand-muted hover:text-white hover:bg-brand-border/60',
                ]}
              >
                <LineIcon name={d.slug} class="w-4 h-4 text-brand-red shrink-0" />{d.nameEs}
              </a>
            ))}
          </div>
        </div>

        <!-- Dropdown: Municipios -->
        <div class="relative" data-dropdown>
          <button
            type="button"
            class:list={[linkBase, 'inline-flex items-center gap-1', isMunicipio ? linkActive : linkIdle]}
            aria-expanded="false"
            aria-haspopup="true"
            data-dropdown-toggle
          >
            Municipios
            <svg class="w-3.5 h-3.5 transition-transform" data-dropdown-chevron fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div
            class="hidden absolute left-0 top-full mt-1 w-56 bg-brand-gray border border-brand-border rounded-xl shadow-xl shadow-black/40 p-2 flex flex-col gap-0.5"
            data-dropdown-panel
          >
            {LOCATIONS.map(l => (
              <a
                href={`/${l.slug}/`}
                class:list={[
                  'px-3 py-2 rounded-lg text-sm transition-colors',
                  isActive(`/${l.slug}/`) ? 'text-white bg-brand-border' : 'text-brand-muted hover:text-white hover:bg-brand-border/60',
                ]}
              >
                {l.name}
              </a>
            ))}
          </div>
        </div>

        <!-- Dropdown: Para ti -->
        <div class="relative" data-dropdown>
          <button
            type="button"
            class:list={[linkBase, 'inline-flex items-center gap-1', isParaTi ? linkActive : linkIdle]}
            aria-expanded="false"
            aria-haspopup="true"
            data-dropdown-toggle
          >
            Para ti
            <svg class="w-3.5 h-3.5 transition-transform" data-dropdown-chevron fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div
            class="hidden absolute left-0 top-full mt-1 w-64 bg-brand-gray border border-brand-border rounded-xl shadow-xl shadow-black/40 p-2 flex flex-col gap-0.5"
            data-dropdown-panel
          >
            {paraTi.map(p => (
              <a
                href={p.href}
                class:list={[
                  'px-3 py-2 rounded-lg text-sm transition-colors',
                  isActive(p.href) ? 'text-white bg-brand-border' : 'text-brand-muted hover:text-white hover:bg-brand-border/60',
                ]}
              >
                {p.label}
              </a>
            ))}
          </div>
        </div>
      </nav>

      <!-- CTA -->
      <div class="flex items-center gap-3">
        <a
          href="/contacto/"
          class="bg-brand-red hover:bg-red-700 text-white text-sm font-semibold px-4 py-2 rounded-md transition-colors"
        >
          Pedir orientación
        </a>
        <!-- Mobile menu button -->
        <button
          id="menu-toggle"
          class="lg:hidden p-2 text-brand-muted hover:text-white"
          aria-label="Abrir menú de navegación"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg class="w-5 h-5" data-icon-open fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg class="w-5 h-5 hidden" data-icon-close fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-brand-border bg-brand-gray max-h-[calc(100vh-4rem)] overflow-y-auto">
    <nav class="px-4 py-4 flex flex-col gap-5" aria-label="Navegación móvil">
      <a href="/centros/" class="px-3 py-2 text-sm font-semibold text-white bg-brand-border/50 rounded-md">
        Directorio de centros
      </a>

      <div>
        <p class="px-3 text-xs font-semibold text-brand-muted uppercase tracking-wider mb-2">Disciplinas</p>
        <div class="grid grid-cols-2 gap-1">
          {DISCIPLINES.map(d => (
            <a href={`/${d.slug}/`} class="flex items-center gap-2 px-3 py-2 text-sm text-brand-muted hover:text-white hover:bg-brand-border rounded-md transition-colors">
              <LineIcon name={d.slug} class="w-4 h-4 text-brand-red shrink-0" />{d.nameEs}
            </a>
          ))}
        </div>
      </div>

      <div>
        <p class="px-3 text-xs font-semibold text-brand-muted uppercase tracking-wider mb-2">Municipios</p>
        <div class="flex flex-col gap-1">
          {LOCATIONS.map(l => (
            <a href={`/${l.slug}/`} class="px-3 py-2 text-sm text-brand-muted hover:text-white hover:bg-brand-border rounded-md transition-colors">
              {l.name}
            </a>
          ))}
        </div>
      </div>

      <div>
        <p class="px-3 text-xs font-semibold text-brand-muted uppercase tracking-wider mb-2">Para ti</p>
        <div class="flex flex-col gap-1">
          {paraTi.map(p => (
            <a href={p.href} class="px-3 py-2 text-sm text-brand-muted hover:text-white hover:bg-brand-border rounded-md transition-colors">
              {p.label}
            </a>
          ))}
        </div>
      </div>

      <div class="border-t border-brand-border pt-3 flex flex-col gap-1">
        <a href="/sobre-nosotros/" class="px-3 py-2 text-sm text-brand-muted hover:text-white rounded-md transition-colors">
          Sobre el proyecto
        </a>
        <a href="/contacto/" class="px-3 py-2 text-sm text-brand-red hover:text-red-400 transition-colors">
          Pedir orientación gratuita →
        </a>
      </div>
    </nav>
  </div>
</header>

<div id="contenido"></div>

<script>
  // Menú móvil
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = toggle?.querySelector('[data-icon-open]');
  const iconClose = toggle?.querySelector('[data-icon-close]');
  toggle?.addEventListener('click', () => {
    const abierto = !menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(abierto));
    iconOpen?.classList.toggle('hidden', abierto);
    iconClose?.classList.toggle('hidden', !abierto);
  });

  // Dropdowns de escritorio: click para abrir, cierre con clic fuera o Escape
  const dropdowns = Array.from(document.querySelectorAll('[data-dropdown]'));
  function cerrarTodos(excepto?: Element) {
    for (const dd of dropdowns) {
      if (dd === excepto) continue;
      dd.querySelector('[data-dropdown-panel]')?.classList.add('hidden');
      dd.querySelector('[data-dropdown-toggle]')?.setAttribute('aria-expanded', 'false');
      dd.querySelector('[data-dropdown-chevron]')?.classList.remove('rotate-180');
    }
  }
  for (const dd of dropdowns) {
    const btn = dd.querySelector('[data-dropdown-toggle]');
    const panel = dd.querySelector('[data-dropdown-panel]');
    const chevron = dd.querySelector('[data-dropdown-chevron]');
    btn?.addEventListener('click', e => {
      e.stopPropagation();
      const abrir = panel?.classList.contains('hidden');
      cerrarTodos(dd);
      panel?.classList.toggle('hidden', !abrir);
      btn.setAttribute('aria-expanded', String(!!abrir));
      chevron?.classList.toggle('rotate-180', !!abrir);
    });
  }
  document.addEventListener('click', () => cerrarTodos());
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') cerrarTodos();
  });
</script>
