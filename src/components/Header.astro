---
const nav = [
  { label: 'Centros', href: '/centros/' },
  { label: 'Disciplinas', href: '/boxeo/' },
  { label: 'Sitges', href: '/sitges/' },
  { label: 'Vilanova', href: '/vilanova-i-la-geltru/' },
  { label: 'Niños', href: '/clases-para-ninos/' },
  { label: 'Mujeres', href: '/clases-para-mujeres/' },
  { label: 'Sobre el proyecto', href: '/sobre-nosotros/' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-brand-dark/95 backdrop-blur border-b border-brand-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 shrink-0">
        <span class="text-brand-red font-black text-xl tracking-tight">AM</span>
        <span class="font-bold text-white text-sm leading-tight hidden sm:block">
          Artes Marciales Garraf<br />
          <span class="text-brand-muted font-normal">La guía de la comarca</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {nav.map(item => (
          <a
            href={item.href}
            class:list={[
              'px-3 py-2 text-sm rounded-md transition-colors',
              currentPath === item.href
                ? 'text-white bg-brand-gray'
                : 'text-brand-muted hover:text-white hover:bg-brand-gray/50',
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- CTA -->
      <div class="flex items-center gap-3">
        <a
          href="/contacto/"
          class="bg-brand-red hover:bg-red-700 text-white text-sm font-semibold px-4 py-2 rounded-md transition-colors"
        >
          Pedir orientación
        </a>
        <!-- Mobile menu button -->
        <button
          id="menu-toggle"
          class="lg:hidden p-2 text-brand-muted hover:text-white"
          aria-label="Abrir menú"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-brand-border bg-brand-gray">
    <nav class="px-4 py-3 flex flex-col gap-1">
      {nav.map(item => (
        <a
          href={item.href}
          class="px-3 py-2 text-sm text-brand-muted hover:text-white hover:bg-brand-border rounded-md transition-colors"
        >
          {item.label}
        </a>
      ))}
      <a
        href="/contacto/"
        class="px-3 py-2 text-sm text-brand-red hover:text-red-400 transition-colors"
      >
        Pedir orientación
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
