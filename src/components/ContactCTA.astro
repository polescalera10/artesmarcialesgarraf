---
interface Props { disciplina?: string; municipio?: string }
const { disciplina, municipio } = Astro.props;
const contexto = disciplina && municipio
  ? `${disciplina.toLowerCase()} en ${municipio}`
  : 'artes marciales en el Garraf';
---

<section class="py-16 px-4">
  <div class="max-w-3xl mx-auto bg-gradient-to-br from-brand-red/20 to-brand-red/5 border border-brand-red/30 rounded-2xl p-8 sm:p-12 text-center">
    <span class="inline-block bg-brand-red/20 text-brand-red text-xs font-semibold px-3 py-1 rounded-full mb-4 uppercase tracking-wider">Orientación gratuita</span>
    <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">
      ¿Quieres empezar a entrenar?
    </h2>
    <p class="text-brand-muted mb-8 max-w-lg mx-auto">
      Cuéntanos qué buscas —disciplina, municipio, edad, objetivo— y te orientamos sin coste sobre cómo empezar con {contexto}. Sin compromiso y sin spam.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/contacto/"
        class="bg-brand-red hover:bg-red-700 text-white font-bold px-8 py-3 rounded-lg transition-colors text-center"
      >
        Pedir orientación gratuita
      </a>
    </div>
  </div>
</section>
