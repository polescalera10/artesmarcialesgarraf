---
import { SITE } from '../data/site';
interface Props { count?: number }
const { count = 6 } = Astro.props;
const items = SITE.testimonials.slice(0, count);
---

<section class="py-16 px-4 bg-brand-gray/50">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-10">
      <h2 class="text-2xl font-bold text-white mb-2">Lo que dicen nuestros alumnos</h2>
      <div class="flex items-center justify-center gap-1 text-yellow-400">
        {"★★★★★".split("").map(s => <span>{s}</span>)}
        <span class="text-brand-muted text-sm ml-2">4.9 · Más de 120 reseñas</span>
      </div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {items.map(t => (
        <div class="bg-brand-gray border border-brand-border rounded-xl p-6">
          <div class="flex items-center gap-0.5 text-yellow-400 mb-3">
            {"★★★★★".split("").map(s => <span class="text-sm">{s}</span>)}
          </div>
          <p class="text-sm text-brand-muted leading-relaxed mb-4">"{t.text}"</p>
          <div class="text-sm font-semibold text-white">{t.name}
            <span class="text-brand-muted font-normal"> · {t.location}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
